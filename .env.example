# TRIB / HIVE Environment Variables
# Same names work on Vercel dashboard and Azure Application Settings

# ---------------------------------------------------------------------------
# Data provider — controls which backend the HIVE handbook uses
# Values: "json" (L0 offline fallback) | "supabase" (Phase A) | "azure" (Phase B)
# ---------------------------------------------------------------------------
DATA_PROVIDER=json

# ---------------------------------------------------------------------------
# Supabase — dedicated HIVE project (separate from shared Sparkworks/Atlas project)
# Required when DATA_PROVIDER=supabase or DATA_PROVIDER=azure (for pgvector)
# ---------------------------------------------------------------------------
HIVE_SUPABASE_URL=https://afysgjiczzptubonbuxs.supabase.co
HIVE_SUPABASE_ANON_KEY=

# Legacy fallback names (used by other parts of the app)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Azure Postgres — Phase B production database
# Required when DATA_PROVIDER=azure
# ---------------------------------------------------------------------------
AZURE_POSTGRES_URL=

# ---------------------------------------------------------------------------
# AI — embeddings + intent detection + report synthesis
# ---------------------------------------------------------------------------
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Analytics — Google Analytics 4
# Optional: leave blank to disable GA4 tracking
# ---------------------------------------------------------------------------
NEXT_PUBLIC_GA4_ID=

# ---------------------------------------------------------------------------
# App
# Phase A: Vercel URL | Phase B: trib.org.uk
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Node
# ---------------------------------------------------------------------------
NODE_ENV=development
